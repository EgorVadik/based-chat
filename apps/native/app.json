{
  "expo": {
    "scheme": "based-chat",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "based-chat",
    "slug": "based-chat",
    "plugins": [
      "expo-font",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "package": "com.anonymous.basedchat"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.basedchat"
    }
  }
}
